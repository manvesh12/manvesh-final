          </div>
        </div>

        <!-- ═══ AUCTION TABLE ═══ -->
        <div id="view-auction-table" class="view">
          <div class="header-row">
            <div>
              <div class="page-title">Proforma for Auctioned Sites — District Jalandhar</div>
              <div class="page-sub">Mining sites auctioned as per DPR guidelines</div>
            </div>
            <div style="display:flex;gap:8px">
              <button class="btn btn-outline btn-sm" onclick="addAuctionRow()">+ Add Row</button>
              <button class="btn btn-teal btn-sm" onclick="toast('Excel downloaded','success')">⬇ Excel</button>
              <button class="btn btn-saffron btn-sm" onclick="exportAuctionPDF()">📄 PDF</button>
            </div>
          </div>
          <div class="card">
            <div class="card-bd" style="overflow-x:auto">
              <table class="tbl" id="auction-tbl" style="min-width:1300px">
                <thead>
                  <tr>
                    <th>Sr No.</th>
                    <th>Site Name</th>
                    <th>Type of Mine</th>
                    <th>Date of Grant</th>
                    <th>Date of Start</th>
                    <th>Qty Allowed EC (MT/yr)</th>
                    <th>Qty Extracted (MT) till 30-Jun-2025</th>
                    <th>Balance Qty (1-Dec-2025)</th>
                    <th>EC Status</th>
                    <th>Reason Not Operated</th>
                    <th>Reason No EC Applied</th>
                    <th>Remarks</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody id="auction-tbody"></tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- ═══ SUMMARY TABLE ═══ -->
        <div id="view-summary-table" class="view">
          <div class="header-row">
            <div>
              <div class="page-title">Source-wise Summary of Excavation Quantity</div>
              <div class="page-sub">District-wise summary for all mining sources</div>
            </div>
            <div style="display:flex;gap:8px">
              <button class="btn btn-outline btn-sm" onclick="addSummaryRow()">+ Add Row</button>
              <button class="btn btn-teal btn-sm" onclick="toast('Excel downloaded','success')">⬇ Excel</button>
              <button class="btn btn-saffron btn-sm" onclick="exportSummaryPDF()">📄 PDF</button>
            </div>
          </div>
          <div class="card">
            <div class="card-bd">
              <div class="tbl-wrap">
                <table class="tbl" id="summary-tbl" style="min-width:900px">
                  <thead>
                    <tr>
                      <th>Source</th>
                      <th>No. of Proposed Sites</th>
                      <th>Area (Ha)</th>
                      <th>Total Excav. (Tonnes)</th>
                      <th>Total Excav. @60% EMGSM 2020 (Tonnes)</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody id="summary-tbody"></tbody>
                  <tfoot>
                    <tr class="total-row">
                      <td><strong>TOTAL</strong></td>
                      <td id="sum-sites">0</td>
                      <td id="sum-area">0</td>
                      <td id="sum-excav">0</td>
                      <td id="sum-excav60">0</td>
                      <td></td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ BENCH MARK TABLE ═══ -->
        <div id="view-benchmark-table" class="view">
          <div class="header-row">
            <div>
              <div class="page-title">Bench Mark & CORS Station</div>
              <div class="page-sub">Survey reference points and CORS station data</div>
            </div>
            <button class="btn btn-saffron btn-sm" onclick="exportAnxPDF('benchmark')">📄 Export PDF</button>
          </div>
          <div class="notif notif-info" style="margin-bottom:14px">This section is also available under Additional
            Annexures. Data is shared.</div>
          <button class="btn btn-outline btn-sm"
            onclick="showView('annexures-extra',null);switchAnxTab('benchmark',null)">Go to Bench Mark Section
            →</button>
        </div>

        <!-- ═══ E-SIGNATURES ═══ -->
        <div id="view-esign" class="view">
          <div class="header-row">
            <div>
              <div class="page-title">E-Signature Panel</div>
              <div class="page-sub">Sequential digital signing workflow · 5-level authority hierarchy</div>
            </div>
          </div>
          <div class="notif notif-info" style="margin-bottom:16px">🔐 Signatures are sequential — each authority must
            complete before the next is notified. Supports DSC, Aadhaar eSign, and OTP-based signing.</div>
          <div id="sig-list" style="display:flex;flex-direction:column;gap:10px"></div>
        </div>

        <!-- ═══ GENERATE PDF ═══ -->
        <div id="view-generate" class="view">
          <div class="header-row">
            <div>
              <div class="page-title">Generate Final DSR PDF</div>
              <div class="page-sub">Professional government-format report with all sections, annexures, and digital
                signatures</div>
            </div>
          </div>
          <div class="g2">
            <div>
              <div class="card" style="margin-bottom:16px">
                <div class="card-hd">
                  <div class="card-title">Completion Checklist</div>
                </div>
                <div class="card-bd" id="final-checklist"></div>
              </div>
              <div class="card">
                <div class="card-hd">
                  <div class="card-title">PDF Options</div>
                </div>
                <div class="card-bd">
                  <div class="field-group">
                    <div class="field-row">
                      <div class="field"><label>District</label><select id="pdf-district">
                          <option>Jalandhar</option>
                          <option>Ludhiana</option>
                          <option>Amritsar</option>
                        </select></div>
                      <div class="field"><label>Year</label><input id="pdf-year" value="2025-26"></div>
                    </div>
                    <div class="field"><label>Report Version</label><input value="Final · Approved Draft"></div>
                  </div>
                  <div class="divider"></div>
                  <div style="display:flex;gap:9px;flex-wrap:wrap">
                    <button class="btn btn-navy" style="display:inline-flex;align-items:center;gap:4px;"
                      onclick="generateFinalPDF()"><i data-lucide="download"
                        style="width:14px;height:14px;"></i>Generate Final PDF</button>
                    <button class="btn btn-teal" style="display:inline-flex;align-items:center;gap:4px;"
                      onclick="submitForReview()"><i data-lucide="send" style="width:14px;height:14px;"></i>Submit to
                      Authority</button>
                  </div>
                </div>
              </div>
            </div>
            <div>
              <div class="card">
                <div class="card-hd">
                  <div class="card-title">PDF Preview</div>
                </div>
                <div class="card-bd">
                  <div class="pdf-preview">
                    <div style="font-size:11px;color:rgba(255,255,255,.6);margin-bottom:10px">Preview — Final DSR Report
                    </div>
                    <div class="pdf-page-thumb">
                      <div class="pdf-page-hd"><span>DISTRICT SURVEY REPORT</span></div>
                      <div class="pdf-page-bd">
                        <div class="pdf-line header"></div>
                        <div class="pdf-line" style="height:8px;background:#e8eaf6;margin:6px 0"></div>
                        <div class="pdf-line medium"></div>
                        <div class="pdf-line short"></div>
                        <div class="pdf-line"></div>
                        <div class="pdf-line medium"></div>
                        <div class="pdf-line short"></div>
                        <div class="pdf-line"></div>
                        <div class="pdf-line medium"></div>
                        <div class="pdf-line" style="height:30px;background:#f5f5f5;margin:6px 0"></div>
                        <div class="pdf-line short"></div>
                        <div class="pdf-line medium"></div>
                        <div class="pdf-line"></div>
                      </div>
                    </div>
                    <div style="font-size:10px;color:rgba(255,255,255,.4);text-align:center">
                      <span id="pdf-page-count">0</span> pages · Ready to generate
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ REPORT HISTORY ═══ -->
        <div id="view-history" class="view">
          <div class="header-row">
            <div>
              <div class="page-title">Report History</div>
              <div class="page-sub">All previous DSR versions, approved reports, and revision history</div>
            </div>
          </div>
          <div class="card">
            <div class="card-bd">
              <div class="tbl-wrap">
                <table class="tbl">
                  <thead>
                    <tr>
                      <th>Report Title</th>
                      <th>District</th>
                      <th>Year</th>
                      <th>Version</th>
                      <th>Generated On</th>
                      <th>Status</th>
                      <th>Signatures</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>DSR — Jalandhar Sand Mining</td>
                      <td>Jalandhar</td>
                      <td>2024-25</td>
                      <td>v3.0 Final</td>
                      <td>Mar 15, 2025</td>
                      <td><span class="badge badge-green">Approved</span></td>
                      <td>5/5</td>
                      <td><button class="btn btn-xs btn-outline">⬇ Download</button></td>
                    </tr>
                    <tr>
                      <td>DSR — Jalandhar Sand Mining</td>
                      <td>Jalandhar</td>
                      <td>2024-25</td>
                      <td>v2.1 Draft</td>
                      <td>Feb 20, 2025</td>
                      <td><span class="badge badge-amber">Rejected</span></td>
                      <td>2/5</td>
                      <td><button class="btn btn-xs btn-outline">👁 View</button></td>
                    </tr>
                    <tr>
                      <td>DSR — Ludhiana Mining Survey</td>
                      <td>Ludhiana</td>
                      <td>2023-24</td>
                      <td>v1.0 Final</td>
                      <td>Jun 5, 2024</td>
                      <td><span class="badge badge-green">Approved</span></td>
                      <td>5/5</td>
                      <td><button class="btn btn-xs btn-outline">⬇ Download</button></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ USER MANAGEMENT ═══ -->
        <div id="view-users" class="view">
          <div class="header-row">
            <div>
              <div class="page-title">User Management</div>
              <div class="page-sub">Manage portal users, roles, permissions, and section access</div>
            </div>
            <button class="btn btn-saffron btn-sm" onclick="toast('Add user form opened','info')">+ Add User</button>
          </div>
          <div class="card">
            <div class="card-bd">
              <div class="tbl-wrap">
                <table class="tbl">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Role</th>
                      <th>Department</th>
                      <th>Status</th>
                      <th>Last Login</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Rajinder Kumar</td>
                      <td>rk@punjab.gov.in</td>
                      <td><span class="badge badge-navy">SDO</span></td>
                      <td>Revenue Dept., Jalandhar</td>
                      <td><span class="badge badge-green">Active</span></td>
                      <td>May 22, 2026</td>
                      <td><button class="btn btn-xs btn-outline">Edit</button></td>
                    </tr>
                    <tr>
                      <td>Dr. Suresh Verma</td>
                      <td>sv@mining.punjab.gov.in</td>
                      <td><span class="badge badge-teal">DMO</span></td>
                      <td>Geology & Mining, Punjab</td>
                      <td><span class="badge badge-green">Active</span></td>
                      <td>May 21, 2026</td>
                      <td><button class="btn btn-xs btn-outline">Edit</button></td>
                    </tr>
                    <tr>
                      <td>Priya Sharma</td>
                      <td>ps@iitropar.ac.in</td>
                      <td><span class="badge badge-indigo">Reviewer</span></td>
                      <td>IIT Ropar Research Cell</td>
                      <td><span class="badge badge-green">Active</span></td>
                      <td>May 22, 2026</td>
                      <td><button class="btn btn-xs btn-outline">Edit</button></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
  <!-- ═══ MODALS ═══ -->
  <!-- Confirm Modal -->
  <div id="modal-confirm" class="modal-overlay">
    <div class="modal-box" style="max-width:400px; max-height: max-content;">
      <div class="modal-hd">
        <h3>Confirm Action</h3><button class="modal-close" onclick="closeModal('modal-confirm')">×</button>
      </div>
      <div class="modal-bd">
        <p id="confirm-msg" style="font-size:14px; color:var(--text); font-weight: 500;"></p>
      </div>
      <div class="modal-ft">
        <button class="btn btn-outline" onclick="closeModal('modal-confirm')">Cancel</button>
        <button class="btn btn-danger" onclick="doConfirm()">Confirm</button>
      </div>
    </div>
  </div>

  <!-- New Project Modal -->
  <div id="modal-project" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-hd">
        <h3>Create New DSR Project</h3><button class="modal-close" onclick="closeModal('modal-project')">×</button>
      </div>
      <div class="modal-bd">
        <div class="field-group">
          <div class="field"><label>Report Title (optional)</label><input id="proj-title"
              placeholder="District Survey Report for Sand Mining"></div>
          <div class="field-row">
            <div class="field"><label>District</label>
              <select id="proj-district">
                <option>Jalandhar</option>
                <option>Ludhiana</option>
                <option>Mansa</option>
                <option>Hoshiarpur</option>
                <option>Pathankot</option>
                <option>Rupnagar</option>
                <option>Tarn Taran</option>
              </select>
            </div>
            <div class="field"><label>Year</label><input id="proj-year" value="2025-26"></div>
          </div>
          <div class="field-row">
            <div class="field"><label>Mineral Type</label>
              <select id="proj-mineral">
                <option>Sand</option>
                <option>RBM</option>
                <option>Bajri</option>
                <option>Gravel</option>
              </select>
            </div>
            <div class="field"><label>River(s)</label><input id="proj-rivers" placeholder="Sutlej, Beas"></div>
          </div>
          <div class="field"><label>Prepared By</label><input id="proj-by" value="Sub-Divisional Committee"></div>
        </div>
      </div>
      <div class="modal-ft">
        <button class="btn btn-outline" onclick="closeModal('modal-project')">Cancel</button>
        <button class="btn btn-saffron" onclick="createProject()">Create Project →</button>
      </div>
    </div>
  </div>

  <!-- Sign Modal -->
  <div id="modal-sign" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-hd">
        <h3 id="sign-modal-title">Digital Signature</h3><button class="modal-close"
          onclick="closeModal('modal-sign')">×</button>
      </div>
      <div class="modal-bd">
        <div id="sign-modal-content"></div>
        <div class="notif notif-warn" style="margin-top:14px; display:flex; align-items:center; gap:8px;">
          <i data-lucide="alert-triangle" style="width:16px; height:16px; flex-shrink:0;"></i>
          <span>By signing, you certify the accuracy of the complete DSR report and EMGSM 2020 compliance.</span>
        </div>
        <div class="field" style="margin-top:14px"><label>OTP Verification (Demo: 123456)</label><input
            class="otp-input" id="sign-otp" maxlength="6" placeholder="——————"
            oninput="this.value=this.value.replace(/\D/g,'')"></div>
      </div>
      <div class="modal-ft">
        <button class="btn btn-outline" onclick="closeModal('modal-sign')">Cancel</button>
        <button class="btn btn-saffron" onclick="doSign()">Confirm & Sign →</button>
      </div>
    </div>
  </div>

  <!-- Authority Sign Modal -->
  <div id="modal-auth-sign" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-hd">
        <h3>Authority E-Signature</h3><button class="modal-close" onclick="closeModal('modal-auth-sign')">×</button>
      </div>
      <div class="modal-bd">
        <div id="auth-sign-content"></div>
        <div class="notif notif-warn" style="margin-top:14px; display:flex; align-items:center; gap:8px;">
          <i data-lucide="alert-triangle" style="width:16px; height:16px; flex-shrink:0;"></i>
          <span>Sequential signing — your approval forwards to the next authority.</span>
        </div>
        <div class="field" style="margin-top:14px"><label>OTP (Demo: 123456)</label><input class="otp-input"
            id="auth-otp" maxlength="6" placeholder="——————" oninput="this.value=this.value.replace(/\D/g,'')"></div>
      </div>
      <div class="modal-ft">
        <button class="btn btn-outline" onclick="closeModal('modal-auth-sign')">Cancel</button>
        <button class="btn btn-saffron" onclick="authoritySign()">Sign & Approve →</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <script src="js/state.js"></script>
  <script src="js/navigation.js"></script>
  <script src="js/auth.js"></script>
  <script src="js/projects.js"></script>
  <script src="js/frontmatter.js"></script>
  <script src="js/chapters.js"></script>
  <script src="js/plates.js"></script>
  <script src="js/graphs.js"></script>
  <script src="js/tables.js"></script>
  <script src="js/anx1.js"></script>
  <script src="js/anx2.js"></script>
  <script src="js/anx3.js"></script>
  <script src="js/anx4.js"></script>
  <script src="js/anx5.js"></script>
  <script src="js/anx6.js"></script>
  <script src="js/anx7.js"></script>
  <script src="js/signatures.js"></script>
  <script src="js/pdf.js"></script>
  <script src="js/main.js"></script>
</body>

</html>